# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/master/Unity.gitignore
#
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Mm]emoryCaptures/

# Unity per-user settings (machine-local, not shared)
/[Uu]serSettings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
[Aa]ssets/Plugins/Editor/JetBrains*

# Roslyn compiler DLLs for MCP execute_code — installed per Editor, restored not committed (see bootstrap.md)
[Aa]ssets/Plugins/Roslyn/

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.unitypackage

# Crashlytics generated file
crashlytics-build.properties

# --- Agent workspace ---
# Snapshots are tracked as context. Scratch and RunLogs are disposable: Scratch is hand working
# files; RunLogs holds tool-emitted JSON diagnostics — re-run the tool for fresh ones. Durable
# findings belong in docs/ or a test — never as a tracked file inside RunLogs/. .gitkeep keeps the
# folder present on a fresh clone. (Rules must follow the stock !*.meta un-ignore above to drop metas.)
/[Aa]ssets/Agent/Scratch/
/[Aa]ssets/Agent/Scratch.meta
/[Aa]ssets/Agent/RunLogs/*
!/[Aa]ssets/Agent/RunLogs/.gitkeep

# --- Git hooks (core.hooksPath = .githooks) ---
# Git LFS regenerates its own hooks (post-checkout/commit/merge, pre-push) via `git lfs install`;
# only our authored pre-commit (the STRUCTURE.md snapshot) is tracked.
/.githooks/*
!/.githooks/pre-commit

# Poiyomi/Thry regenerated material caches + presets at project root (machine-local)
/Thry/

# --- Untouched vendor imports ---
# Reproducible by re-importing the source .unitypackage (kept on the asset library).
# Our work lives elsewhere under Assets/ and references vendor assets by GUID, so it
# survives a bare re-import. Must come after the !*.meta rule above to also drop metas.
/[Aa]ssets/Vendor/
/[Aa]ssets/Vendor.meta

# Texture-work source art (.psd) lives outside Assets so edits don't trigger an editor
# refresh. PSDs we bring over are our modified variants (the package ships the PNG exports).
/Photoshop/

# Blender auto-backups — regenerated on every save, not worth versioning.
*.blend1

# --- Large binaries: gitignored, NOT version-controlled (use an external backup) ---
# Git's value here is diffable text (YAML / .meta / json); binaries get no diff benefit and bloat
# history + LFS quota. We keep each binary's tracked .meta (GUID + import settings — preserved by the
# !*.meta un-ignore above), so YAML refs still resolve and a restored or re-exported file rebinds.
# The binaries live outside Git, so keep them under an external backup for full coverage. Trade-off:
# a fresh clone lacks meshes/textures until restored/re-exported.
*.fbx
*.blend
*.psd
*.psb
*.tga
*.png
*.jpg
*.jpeg
*.exr
*.hdr
*.tif
*.tiff
*.wav
*.aiff
*.mp3
*.ogg
*.mp4

